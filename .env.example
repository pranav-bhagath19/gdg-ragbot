# ─── COPY THIS FILE TO .env AND FILL IN YOUR VALUES ───────────────────────────
# cp .env.example .env

# ─── REQUIRED: LLM API Keys ───────────────────────────────────────────────────

# Groq API Key (Primary LLM - FREE)
# Get from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_API_KEY_BACKUP=your_groq_api_key_backup_here

# Google Gemini API Key (Fallback LLM - FREE)
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_KEY_BACKUP=your_gemini_api_key_backup_here

# ─── STORAGE ──────────────────────────────────────────────────────────────────

# Path to persist hnswlib index + metadata
# For Render/Railway: use /var/data or the mounted disk path
STORAGE_PATH=./data
PDF_FOLDER=./data

# ─── LIMITS ───────────────────────────────────────────────────────────────────

MAX_FILE_SIZE_MB=10
MAX_DOCS=100

# ─── OPTIONAL ─────────────────────────────────────────────────────────────────

DEBUG=false
RATE_LIMIT_PER_MINUTE=30
TOP_K_CHUNKS=5
CHUNK_SIZE=512
CHUNK_OVERLAP=64
